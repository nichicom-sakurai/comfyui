{
  "1": {
    "class_type": "LoadImage",
    "inputs": { "image": "yokkorasho_pose3_kneeext.png" },
    "_meta": { "title": "画像読み込み（ポーズ3参照）" }
  },
  "2": {
    "class_type": "OpenposePreprocessor",
    "inputs": { "image": ["1", 0], "detect_hand": "disable", "detect_body": "enable", "detect_face": "disable", "resolution": 512 },
    "_meta": { "title": "OpenPose 前処理" }
  },
  "3": {
    "class_type": "BatchImagesNode",
    "inputs": { "images": { "image_0": ["1", 0], "image_1": ["2", 0] } },
    "_meta": { "title": "参照画像バッチ結合（実写＋骨格）" }
  },
  "4": {
    "class_type": "GeminiImageNode",
    "inputs": {
      "prompt": "ラフな絵コンテスケッチ、モノクロの鉛筆線画、粗く表現力のある線。添付した2枚の参照画像（実写フレームとOpenPose骨格図）のポーズ・関節角度を忠実に再現すること。特に骨格図の関節位置を優先して姿勢を再現する。椅子に座り片脚を前方に伸ばしている特徴のない汎用マネキン人形として描く。もう片方の足は床にしっかりつけている、両手はバランスを取るため椅子の座面横に置いている。椅子と伸ばした脚がはっきり分かる正面斜め45度のカメラアングル。無地の背景。プロダクション用絵コンテイラストのスタイルで、写真のようなリアルさ・カラー・高齢者特有の特徴は避けること。",
      "model": "gemini-2.5-flash-image",
      "seed": 1003,
      "images": ["3", 0],
      "aspect_ratio": "16:9",
      "response_modalities": "IMAGE"
    },
    "_meta": { "title": "Nano Banana 画像生成（Gemini）" }
  },
  "5": {
    "class_type": "SaveImage",
    "inputs": { "filename_prefix": "nanobanana_yokkorasho_pose3_kneeext", "images": ["4", 0] },
    "_meta": { "title": "画像保存" }
  }
}
